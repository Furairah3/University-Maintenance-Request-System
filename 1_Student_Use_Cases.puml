@startuml Student_Use_Cases

title Smart Hostel Maintenance System — Student Module
caption CS415 Software Engineering | Group 11 | Ashesi University

left to right direction

actor "Student" as S

rectangle "System Boundary" {

  usecase "Register with\nuniversity email" as UC1
  usecase "Login / Logout" as UC2
  usecase "Submit maintenance\nrequest" as UC3
  usecase "View personal\ndashboard" as UC4
  usecase "View request\ndetail & status" as UC5
  usecase "Re-open request\n(48 hr window)" as UC6
  usecase "Manage notification\npreferences" as UC7

  usecase "Select category" as UC_CAT
  usecase "Attach image\n(JPEG/PNG, 5MB)" as UC_IMG
  usecase "Validate file\nupload" as UC_VAL
  usecase "Hash password\n(bcrypt)" as UC_HASH
  usecase "Send email\nnotification" as UC_EMAIL
  usecase "In-app notification\n(bell icon)" as UC_BELL
}

S --> UC1
S --> UC2
S --> UC3
S --> UC4
S --> UC5
S --> UC6
S --> UC7

UC3 ..> UC_CAT : <<include>>
UC3 ..> UC_VAL : <<include>>
UC_IMG ..> UC3 : <<extend>>
UC_IMG ..> UC_VAL : <<include>>
UC1 ..> UC_HASH : <<include>>
UC6 ..> UC_EMAIL : <<include>>
UC6 ..> UC_BELL : <<include>>

@enduml
