@startuml Admin_Use_Cases

title Smart Hostel Maintenance System — Admin Module
caption CS415 Software Engineering | Group 11 | Ashesi University

left to right direction

actor "Administrator" as A

rectangle "System Boundary" {

  usecase "View centralized\ndashboard" as UC1
  usecase "Filter requests\n(status/category/\npriority/date)" as UC2
  usecase "Search by student\nname or title" as UC3
  usecase "View full request\ndetails & image" as UC4
  usecase "Set priority\n(High/Medium/Low)" as UC5
  usecase "Assign request\nto staff" as UC6
  usecase "Bulk status\nupdate" as UC7
  usecase "Create staff\naccount" as UC8
  usecase "Edit staff\ndetails" as UC9
  usecase "Deactivate staff\naccount" as UC10
  usecase "View staff\nworkload count" as UC11
  usecase "View avg response\ntime metric" as UC12
  usecase "View avg completion\ntime metric" as UC13
  usecase "View charts\n(category & priority)" as UC14
  usecase "Manage categories\n(add/edit/disable)" as UC15
  usecase "Archive request\n(soft delete)" as UC16

  usecase "Send email\nnotification" as UC_EMAIL
  usecase "Hash password\n(bcrypt)" as UC_HASH
  usecase "Record in\nstatus history" as UC_LOG
}

A --> UC1
A --> UC2
A --> UC3
A --> UC4
A --> UC5
A --> UC6
A --> UC7
A --> UC8
A --> UC9
A --> UC10
A --> UC11
A --> UC12
A --> UC13
A --> UC14
A --> UC15
A --> UC16

UC6 ..> UC_EMAIL : <<include>>
UC7 ..> UC_EMAIL : <<include>>
UC7 ..> UC_LOG : <<include>>
UC5 ..> UC_LOG : <<include>>
UC8 ..> UC_HASH : <<include>>

@enduml
